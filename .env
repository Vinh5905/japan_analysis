# Shared infrastructure
INFRA_COMPOSE_PROJECT_NAME=japan_analysis_infra
SHARED_NETWORK_NAME=crawler_shared_net

# SUUMO source crawler
CRAWLER_COMPOSE_PROJECT_NAME=suumo_source_crawler
APP_ENV=local
TZ=Asia/Ho_Chi_Minh

# PostgreSQL
POSTGRES_IMAGE=postgres:16.3-bookworm
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=japan_analysis
POSTGRES_USER=japan_analysis_user
POSTGRES_PASSWORD=japan_analysis_password_change_me
POSTGRES_INITDB_ARGS=--encoding=UTF8 --locale=C
PGDATA=/var/lib/postgresql/data/pgdata

# MinIO
MINIO_IMAGE=minio/minio:RELEASE.2024-07-16T23-46-41Z
MINIO_MC_IMAGE=minio/mc:RELEASE.2024-07-15T17-46-06Z
MINIO_HOST=minio
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me
MINIO_DEFAULT_BUCKETS=suumo

# Python crawler
PYTHON_IMAGE=python:3.12.4-slim-bookworm
PYTHON_SERVICE_PORT=8000
PYTHONPATH=/app/src
